import tkinter as tk
import serial
import time

try: 
    # CHANGW THIS BASED ON THE SERIAL PORT!!!!
    arduino = serial.Serial('COM3', 9600, timeout=1)
    time.sleep(2)
    print("Arduino connected successfully")
except Exception as e:
    print("Arduino connection failed:", e)
    arduino = None

def send_command(command):
    if arduino and arduino.is_open:
        try:
            arduino.write((command + '\n').encode())
            print(f"Sent command: {command}")
        except Exception as e:
            print("Failed to send command:", e)
def turnOn():
    valve_num = valve.get()
    send_command(f'ON:{valve_num}')


def turnOff():
    valve_num = valve.get()
    send_command(f'OFF:{valve_num}')


def eStop():
    send_command('STOP')

root = tk.Tk()
root.title("Single Valve Test")
root.geometry("700x500")

tk.Label(root, text="Valve input(Only have 9 in the code but feel free to add more):", font=("Papyrus", 16)).pack(pady=10)
valve = tk.Entry(root, font=("Papyrus", 16))
valve.pack(pady=10)
tk.Button(root, text="On", font=("Times New Roman", 16), command=turnOn, bg="green",fg="white").pack(pady=10)
tk.Button(root, text="Off", font=("Times New Roman", 16), command=turnOff, bg="red",fg="white").pack(pady=10)
tk.Button(root, text="Emergency Stop", font=("Times New Roman", 16), command=eStop, bg="black",fg="white").pack(pady=10)



root.mainloop()