class App(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("ALD R150 Control System")
        self.geometry("900x820")
        self.configure(bg="#e0e0e0")

        self.arduino_mgr = ArduinoManager()
        self.process_running = False

        # Track current setpoints so overheat monitor knows the limits
        self._setpoints = {
            "Reactor":    None,
            "Precursor_A": None,
            "Precursor_B": None,
        }
        # Which heater sensors have already shown a warning this process
        self._overheat_warned = set()

        self.create_toolbar()
        self.create_header()
        self.create_emergency_stops()
        self.create_main_content()

        # Start the background overheat monitor (runs every 1 s via after())
        self._schedule_overheat_check()

        self.protocol("WM_DELETE_WINDOW", self.on_closing)

    # ------------------------------------------------------------------
    # UI construction
    # ------------------------------------------------------------------

    def create_toolbar(self):
        toolbar = tk.Frame(self, bg="#263238", height=50)
        toolbar.pack(fill="x", side="top")

        btn_style = dict(
            font=("Arial", 11, "bold"), bg="#37474F", fg="white",
            activebackground="#546E7A", activeforeground="white",
            bd=0, padx=7, pady=8, cursor="hand2")

        tk.Button(toolbar, text="⚙ Valves",
                  command=self.open_valves, **btn_style).pack(
                      side="left", padx=5, pady=8)
        tk.Button(toolbar, text="📋 Recipes",
                  command=self.open_recipes, **btn_style).pack(
                      side="left", padx=5, pady=8)
        tk.Button(toolbar, text="🔌 Arduino",
                  command=self.open_arduino, **btn_style).pack(
                      side="left", padx=5, pady=8)
        tk.Button(toolbar, text="🔥 Heater",
                  command=self.open_heater, **btn_style).pack(
                      side="left", padx=5, pady=8)
        tk.Button(toolbar, text="💨 MFC",
                  command=self.open_mfc, **btn_style).pack(
                      side="left", padx=5, pady=8)

        self.conn_indicator = tk.Label(
            toolbar, text="● Disconnected",
            font=("Arial", 10), bg="#263238", fg="#f44336", padx=10)
        self.conn_indicator.pack(side="right", padx=0)

        self.start_btn = tk.Button(
            toolbar, text="▶ START", command=self.start_process,
            font=("Arial", 11, "bold"), bg="#4CAF50", fg="white",
            padx=20, pady=8, bd=0, cursor="hand2",
            activebackground="#45a049")
        self.start_btn.pack(side="right", padx=10, pady=8)

        tk.Button(toolbar, text="■ STOP", command=self.stop_process,
                  font=("Arial", 11, "bold"), bg="#f44336", fg="white",
                  padx=20, pady=8, bd=0, cursor="hand2",
                  activebackground="#da190b").pack(
                      side="right", padx=5, pady=8)

        self._update_connection_indicator()

    def create_header(self):
        header = tk.Frame(self, bg="#e0e0e0")
        header.pack(pady=10)
        tk.Label(header, text="ALD R150 Control System",
                 font=("Arial", 20, "bold"),
                 bg="#e0e0e0", fg="#263238").pack()

    def create_emergency_stops(self):
        frm = tk.Frame(self, bg="#e0e0e0")
        frm.pack(pady=8)
        tk.Button(frm, text="⚠ EMERGENCY STOP ⚠",
                  command=self.emergency_stop,
                  font=("Arial", 11, "bold"), bg="#d32f2f", fg="white",
                  width=8, height=2, relief="raised", bd=3,
                  cursor="hand2", activebackground="#b71c1c").pack(pady=5)

    def create_main_content(self):
        content = tk.Frame(self, bg="#e0e0e0")
        content.pack(fill="both", expand=True, padx=20, pady=8)

        # Active recipe selector
        recipe_frame = tk.LabelFrame(content, text="Active Recipe",
                                     font=("Arial", 11, "bold"),
                                     bg="#f0f0f0", padx=15, pady=10)
        recipe_frame.pack(fill="x", pady=5)

        row = tk.Frame(recipe_frame, bg="#f0f0f0")
