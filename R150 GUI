import tkinter as tk
from tkinter import ttk, messagebox
import json
import os
import serial
import serial.tools.list_ports
import threading
import time

RECIPES_FILE = "ald_recipes.json"

# Sensor names and display labels
TEMP_SENSORS = {
    "Reactor":      "Reactor",
    "Precursor_A":  "Precursor A",
    "Precursor_B":  "Precursor B",
    "Heater_Reactor":  "Heater (Reactor)",
    "Heater_PrecA":    "Heater (Prec. A)",
    "Heater_PrecB":    "Heater (Prec. B)",
}

# How many degrees above setpoint triggers the overheat warning
OVERHEAT_MARGIN = 20.0


class ArduinoManager:
    def __init__(self):
        self.serial_conn = None
        self.connected = False
        self.reading_thread = None
        self.running = False
        self.temp_data = {k: "--" for k in TEMP_SENSORS}
        self.callbacks = []

    def connect(self, port, baudrate=9600):
        try:
            self.serial_conn = serial.Serial(port, baudrate, timeout=1)
            time.sleep(2)          # wait for Arduino reset
            self.connected = True
            self.running = True
            self.reading_thread = threading.Thread(
                target=self._read_loop, daemon=True)
            self.reading_thread.start()
            return True
        except Exception as e:
            print(f"Connection error: {e}")
            return False

    def disconnect(self):
        self.running = False
        self.connected = False
        if self.serial_conn:
            self.serial_conn.close()
            self.serial_conn = None

    def send_command(self, command):
        """Send a newline-terminated command to the Arduino."""
        if self.connected and self.serial_conn:
            try:
                self.serial_conn.write(f"{command}\n".encode())
                return True
            except Exception as e:
                print(f"Send error: {e}")
                return False
        return False

    def emergency_stop(self):
        self.send_command("EMERGENCY_STOP")

    def get_temp(self, sensor_name):
        """Return float temperature for sensor, or None if unavailable."""
        temp_str = self.temp_data.get(sensor_name, "--")
        if temp_str == "--":
            return None
        try:
            return float(temp_str)
        except ValueError:
            return None

    def _read_loop(self):
        while self.running:
            if self.serial_conn and self.serial_conn.in_waiting:
                try:
                    line = self.serial_conn.readline().decode().strip()
                    self._parse_data(line)
                except Exception as e:
                    print(f"Read error: {e}")
            time.sleep(0.05)   # 50 ms poll — responsive but not CPU-heavy

    def _parse_data(self, line):
        """
        Expected format from Arduino:
            TEMP:<SENSOR_NAME>:<value>
        e.g.
            TEMP:Reactor:150.3
            TEMP:Heater_Reactor:152.1
        """
        try:
            if line.startswith("TEMP:"):
                parts = line.split(":")
                if len(parts) == 3:
                    sensor, temp = parts[1], parts[2]
                    if sensor in self.temp_data:
                        self.temp_data[sensor] = temp
                        for cb in self.callbacks:
                            cb(self.temp_data)
        except Exception as e:
            print(f"Parse error: {e}")

    def register_callback(self, callback):
        self.callbacks.append(callback)


