            f"Overheat warning threshold: setpoint + {OVERHEAT_MARGIN:.0f} °C")
        

    # ------------------------------------------------------------------
    # Helpers
    # ------------------------------------------------------------------

    def refresh_recipe_list(self):
        if os.path.exists(RECIPES_FILE):
            with open(RECIPES_FILE, "r") as f:
                recipes = json.load(f)
            names = list(recipes.keys())
        else:
            names = []

        self.active_recipe_menu['values'] = names if names else ["None"]
        self.active_recipe_var.set(names[0] if names else "None")

    def _update_connection_indicator(self):
        if self.arduino_mgr.connected:
            self.conn_indicator.config(text="● Connected", fg="#4CAF50")
        else:
            self.conn_indicator.config(text="● Disconnected", fg="#f44336")
        self.after(500, self._update_connection_indicator)

    def log_message(self, message):
        self.status_text.config(state="normal")
        ts = time.strftime("%H:%M:%S")
        self.status_text.insert("end", f"[{ts}] {message}\n")
        self.status_text.see("end")
        self.status_text.config(state="disabled")

    # ------------------------------------------------------------------
    # Overheat monitoring  (runs in the Tk main-thread via after())
    # ------------------------------------------------------------------

    def _schedule_overheat_check(self):
        self._check_overheat()
        self.after(1000, self._schedule_overheat_check)

    # Mapping heater sensor → process sensor it guards
    _HEATER_MAP = {
        "Heater_Reactor": "Reactor",
        "Heater_PrecA":   "Precursor_A",
        "Heater_PrecB":   "Precursor_B",
    }

    def _check_overheat(self):
        """
        For each heater sensor, compare its temperature against the
        corresponding setpoint.  Warn once per process run if the heater
        exceeds setpoint + OVERHEAT_MARGIN.
        """
        for heater_sensor, proc_sensor in self._HEATER_MAP.items():
            setpoint = self._setpoints.get(proc_sensor)
            if setpoint is None:
                continue   # no setpoint active

            heater_temp = self.arduino_mgr.get_temp(heater_sensor)
            if heater_temp is None:
                continue   # no reading yet

            limit = setpoint + OVERHEAT_MARGIN

            if heater_temp > limit:
                # Highlight the label in the monitoring panel
                self.thermo.flag_overheat(heater_sensor)

                if heater_sensor not in self._overheat_warned:
                    self._overheat_warned.add(heater_sensor)
                    display = TEMP_SENSORS.get(heater_sensor, heater_sensor)
                    msg = (
                        f"⚠ OVERHEAT WARNING: {display}\n\n"
                        f"Current: {heater_temp:.1f} °C\n"
                        f"Setpoint: {setpoint:.1f} °C\n"
                        f"Limit ({OVERHEAT_MARGIN:.0f} °C above setpoint): "
                        f"{limit:.1f} °C\n\n"
                        "Check heater / PID settings immediately!"
                    )
                    self.log_message(
                        f"⚠ OVERHEAT: {display} = {heater_temp:.1f} °C "
                        f"(limit {limit:.1f} °C)")
                    messagebox.showwarning("Overheat Warning", msg)
            else:
                # Temperature back in range — reset warning so it can fire again
                self._overheat_warned.discard(heater_sensor)
                self.thermo.clear_overheat(heater_sensor)

