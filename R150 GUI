class ThermocoupleFrame(tk.LabelFrame):
    def __init__(self, parent, arduino_mgr):
        super().__init__(parent, text="Temperature Monitoring",
                         padx=15, pady=15,
                         font=("Arial", 11, "bold"), bg="#f0f0f0")
        self.arduino_mgr = arduino_mgr
        self.labels = {}
        self._overheat_warned = set()   # sensors already warned this session

        for sensor_key, display_name in TEMP_SENSORS.items():
            frame = tk.Frame(self, bg="#f0f0f0")
            frame.pack(fill="x", pady=4)

            tk.Label(frame, text=f"{display_name}:", font=("Arial", 11),
                     bg="#f0f0f0", width=18, anchor="w").pack(side="left")

            lbl = tk.Label(frame, text="-- °C", font=("Arial", 11, "bold"),
                           bg="white", width=14, relief="sunken",
                           anchor="e", padx=5)
            lbl.pack(side="left", padx=5)
            self.labels[sensor_key] = lbl

        self.arduino_mgr.register_callback(self.update_temps)

    def update_temps(self, temp_data):
        for sensor_key, lbl in self.labels.items():
            val = temp_data.get(sensor_key, "--")
            lbl.config(text=f"{val} °C", bg="white", fg="black")

    def flag_overheat(self, sensor_key):
        """Highlight the sensor label red."""
        if sensor_key in self.labels:
            self.labels[sensor_key].config(bg="#ffcccc", fg="#c62828")

    def clear_overheat(self, sensor_key):
        """Reset sensor label colour."""
        if sensor_key in self.labels:
            self.labels[sensor_key].config(bg="white", fg="black")


