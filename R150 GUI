class HeaterWindow(tk.Toplevel):
    def __init__(self, parent, arduino_mgr):
        super().__init__(parent)
        self.title("Heater Control")
        self.geometry("520x420")
        self.configure(bg="#f0f0f0")
        self.arduino_mgr = arduino_mgr

        tk.Label(self, text="Heater Control Panel",
                 font=("Arial", 14, "bold"), bg="#f0f0f0").pack(pady=15)

        heaters = [
            ("Reactor Heater",     "REACTOR"),
            ("Precursor A Heater", "PRECURSOR_A"),
            ("Precursor B Heater", "PRECURSOR_B"),
        ]

        self._vars = {}
        for label, key in heaters:
            frm = tk.LabelFrame(self, text=label,
                                font=("Arial", 11, "bold"), bg="#f0f0f0",
                                padx=15, pady=10)
            frm.pack(pady=8, padx=20, fill="x")

            row = tk.Frame(frm, bg="#f0f0f0")
            row.pack()

            tk.Label(row, text="Set Temperature (°C):",
                     font=("Arial", 11), bg="#f0f0f0").pack(
                         side="left", padx=5)

            var = tk.StringVar()
            self._vars[key] = var
            tk.Entry(row, textvariable=var, font=("Arial", 10),
                     width=10).pack(side="left", padx=5)

            tk.Button(row, text="Set",
                      command=lambda k=key: self._set_temp(k),
                      font=("Arial", 11), bg="#2196F3", fg="white",
                      width=8).pack(side="left", padx=10)

    def _set_temp(self, heater_key):
        raw = self._vars[heater_key].get().strip()
        if not raw.replace('.', '', 1).lstrip('-').isdigit():
            messagebox.showerror("Error", "Please enter a valid temperature")
            return
        self.arduino_mgr.send_command(f"TEMP_SETPOINT:{heater_key}:{raw}")
        messagebox.showinfo("Success",
                            f"{heater_key} setpoint → {raw} °C")

class MFCWindow(tk.Toplevel):
    MFC_CHANNELS = [
        ("Carrier Gas (N₂)",    "CARRIER"),
        ("Precursor A Carrier", "PREC_A"),
        ("Precursor B Carrier", "PREC_B"),
    ]

    def __init__(self, parent, arduino_mgr):
        super().__init__(parent)
        self.title("MFC Control")
        self.geometry("520x420")
        self.configure(bg="#f0f0f0")
        self.arduino_mgr = arduino_mgr
        self._setpoint_vars = {}
        self._flow_labels = {}

        tk.Label(self, text="Mass Flow Controller (MFC) Control",
                 font=("Arial", 14, "bold"), bg="#f0f0f0").pack(pady=15)

        for label, key in self.MFC_CHANNELS:
            frm = tk.LabelFrame(self, text=label, font=("Arial", 11, "bold"),
                                bg="#f0f0f0", padx=15, pady=10)
            frm.pack(pady=6, padx=20, fill="x")

            sp_row = tk.Frame(frm, bg="#f0f0f0")
            sp_row.pack(fill="x", pady=3)

            tk.Label(sp_row, text="Setpoint (sccm):", font=("Arial", 10),
                     bg="#f0f0f0", width=18, anchor="w").pack(side="left")

            sp_var = tk.StringVar()
            self._setpoint_vars[key] = sp_var
            tk.Entry(sp_row, textvariable=sp_var, font=("Arial", 10),
                     width=10).pack(side="left", padx=5)

            tk.Button(sp_row, text="Set",
                      command=lambda k=key: self._set_flow(k),
                      font=("Arial", 10), bg="#2196F3", fg="white",
                      width=6).pack(side="left", padx=5)

            tk.Button(sp_row, text="Off",
                      command=lambda k=key: self._flow_off(k),
                      font=("Arial", 10), bg="#f44336", fg="white",
                      width=6).pack(side="left", padx=5)

            fb_row = tk.Frame(frm, bg="#f0f0f0")
            fb_row.pack(fill="x", pady=3)

            tk.Label(fb_row, text="Actual (sccm):", font=("Arial", 10),
                     bg="#f0f0f0", width=18, anchor="w").pack(side="left")

            flow_lbl = tk.Label(fb_row, text="--", font=("Arial", 10, "bold"),
                                bg="white", width=10, relief="sunken",
                                anchor="e", padx=5)
            flow_lbl.pack(side="left", padx=5)
            self._flow_labels[key] = flow_lbl

        self.arduino_mgr.register_callback(self._on_data)

    def _set_flow(self, key):
        raw = self._setpoint_vars[key].get().strip()
        if not raw.replace('.', '', 1).isdigit():
            messagebox.showerror("Error", "Enter a valid flow rate (sccm)")
            return
        self.arduino_mgr.send_command(f"MFC_SETPOINT:{key}:{raw}")
        messagebox.showinfo("MFC", f"{key} setpoint → {raw} sccm")

    def _flow_off(self, key):
        self._setpoint_vars[key].set("0")
        self.arduino_mgr.send_command(f"MFC_SETPOINT:{key}:0")

    def _on_data(self, temp_data):
        for key, lbl in self._flow_labels.items():
            lbl.config(text=temp_data.get(f"FLOW_{key}", "--"))


