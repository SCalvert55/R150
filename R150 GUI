    # ------------------------------------------------------------------
    # Recipe loading & temperature checking
    # ------------------------------------------------------------------

    def _load_selected_recipe(self):
        name = self.active_recipe_var.get()
        if name == "None":
            raise ValueError("No recipe selected")
        if not os.path.exists(RECIPES_FILE):
            raise FileNotFoundError("No recipes file found")
        with open(RECIPES_FILE, "r") as f:
            recipes = json.load(f)
        if name not in recipes:
            raise KeyError(f"Recipe '{name}' not found")
        data = recipes[name]
        data["name"] = name
        """
        for field in ("temp_reactor", "temp_precursor_a", "temp_precursor_b"):
            if not data.get(field):
                raise ValueError(
                    f"Recipe missing {field.replace('_', ' ')}")
        """
        return data

    def check_temperatures_ready(self, recipe):
        target_r  = float(recipe["temp_reactor"])
        target_pa = float(recipe["temp_precursor_a"])
        target_pb = float(recipe["temp_precursor_b"])
        tol       = float(recipe.get("temp_tolerance", 2.0))

        tr  = self.arduino_mgr.get_temp("Reactor")
        tpa = self.arduino_mgr.get_temp("Precursor_A")
        tpb = self.arduino_mgr.get_temp("Precursor_B")

        if None in (tr, tpa, tpb):
            self.log_message("Cannot verify temperatures — readings not yet available")
            return False

        ok_r  = abs(tr  - target_r)  <= tol
        ok_pa = abs(tpa - target_pa) <= tol
        ok_pb = abs(tpb - target_pb) <= tol

        if ok_r and ok_pa and ok_pb:
            self.log_message("All temperatures verified at setpoint ✓")
            return True

        if not ok_r:
            self.log_message(f"  Reactor: {tr:.1f} °C  (need {target_r} °C)")
        if not ok_pa:
            self.log_message(f"  Prec. A: {tpa:.1f} °C  (need {target_pa} °C)")
        if not ok_pb:
            self.log_message(f"  Prec. B: {tpb:.1f} °C  (need {target_pb} °C)")
        return False

    def _wait_for_temperatures(self, recipe):
        """Block (in worker thread) until temperatures stabilise or timeout."""
        self.log_message("Waiting for temperatures to stabilise…")

        target_r  = float(recipe["temp_reactor"])
        target_pa = float(recipe["temp_precursor_a"])
        target_pb = float(recipe["temp_precursor_b"])
        tol       = float(recipe.get("temp_tolerance", 2.0))

        deadline = time.time() + 1800   # 30-minute max
        while self.process_running:
            if time.time() > deadline:
                raise TimeoutError("Temperature stabilisation timeout (30 min)")

            tr  = self.arduino_mgr.get_temp("Reactor")
            tpa = self.arduino_mgr.get_temp("Precursor_A")
            tpb = self.arduino_mgr.get_temp("Precursor_B")

            if None in (tr, tpa, tpb):
                self.log_message("Waiting for valid temperature readings…")
                time.sleep(2)
                continue

            ok_r  = abs(tr  - target_r)  <= tol
            ok_pa = abs(tpa - target_pa) <= tol
            ok_pb = abs(tpb - target_pb) <= tol

            self.log_message(
                f"Reactor {tr:.1f}/{target_r} °C {'✓' if ok_r else '✗'}  |  "
                f"PrecA {tpa:.1f}/{target_pa} °C {'✓' if ok_pa else '✗'}  |  "
                f"PrecB {tpb:.1f}/{target_pb} °C {'✓' if ok_pb else '✗'}")

            if ok_r and ok_pa and ok_pb:
                self.log_message("All temperatures at setpoint — starting recipe.")
                return True

            time.sleep(2)

        return False   # process was stopped externally

    # ------------------------------------------------------------------
    # Process execution
    # ------------------------------------------------------------------

    def run_recipe(self, recipe):
        try:
            self.log_message("=" * 50)
            self.log_message(f"Recipe:         {recipe['name']}")
            self.log_message(f"Reactor target: {recipe['temp_reactor']} °C")
            self.log_message(f"PrecA target:   {recipe['temp_precursor_a']} °C")
            self.log_message(f"PrecB target:   {recipe['temp_precursor_b']} °C")
            self.log_message("=" * 50)

            # Store setpoints for the overheat monitor
            self._setpoints["Reactor"]    = float(recipe["temp_reactor"])
            self._setpoints["Precursor_A"] = float(recipe["temp_precursor_a"])
            self._setpoints["Precursor_B"] = float(recipe["temp_precursor_b"])
            self._overheat_warned.clear()

            # Send setpoints and enable PID
            self.arduino_mgr.send_command(f"R:{recipe['temp_reactor']}")
            self.arduino_mgr.send_command(f"A:{recipe['temp_precursor_a']}")
            self.arduino_mgr.send_command(f"B:{recipe['temp_precursor_b']}")

            # Wait for stabilisation
            if not self._wait_for_temperatures(recipe):
                self.log_message("Process cancelled during temperature stabilisation")
                return

            # Parse cycle parameters
            cycles  = int(recipe.get("cycles", 1))
            pulse_a = float(recipe.get("pulse_a", 0.5))
            purge_a = float(recipe.get("purge_a", 5.0))
            pulse_b = float(recipe.get("pulse_b", 0.5))
            purge_b = float(recipe.get("purge_b", 5.0))

            self.log_message(f"Starting {cycles} ALD cycle(s)")

            for cycle in range(1, cycles + 1):
                if not self.process_running:
                    self.log_message("Process stopped by user")
                    break

                self.log_message(f"── Cycle {cycle}/{cycles} ──")

                # --- Pulse A ---
                self.log_message(f"  Pulse A  ({pulse_a:.2f} s)")
                self.arduino_mgr.send_command("VALVE:Precursor_A:OPEN")
                time.sleep(pulse_a)
                self.arduino_mgr.send_command("VALVE:Precursor_A:CLOSE")
                if not self.process_running:
                    break

                # --- Purge A ---
                self.log_message(f"  Purge A  ({purge_a:.2f} s)")
                self.arduino_mgr.send_command("VALVE:Purge_Gas:OPEN")
                time.sleep(purge_a)
                self.arduino_mgr.send_command("VALVE:Purge_Gas:CLOSE")
                if not self.process_running:
                    break

                # --- Pulse B ---
                self.log_message(f"  Pulse B  ({pulse_b:.2f} s)")
                self.arduino_mgr.send_command("VALVE:Precursor_B:OPEN")
                time.sleep(pulse_b)
                self.arduino_mgr.send_command("VALVE:Precursor_B:CLOSE")
                if not self.process_running:
                    break

                # --- Purge B ---
                self.log_message(f"  Purge B  ({purge_b:.2f} s)")
                self.arduino_mgr.send_command("VALVE:Purge_Gas:OPEN")
                time.sleep(purge_b)
                self.arduino_mgr.send_command("VALVE:Purge_Gas:CLOSE")

            if self.process_running:
                self.log_message("✓ Recipe completed successfully!")

        except Exception as e:
            self.log_message(f"ERROR: {e}")

        finally:
            self.process_running = False
            # Clear setpoints so overheat monitor goes idle
            for k in self._setpoints:
                self._setpoints[k] = None
            self._overheat_warned.clear()
            self.start_btn.config(state="normal")
            for zone in ("REACTOR", "PRECURSOR_A", "PRECURSOR_B"):
                self.arduino_mgr.send_command(f"PID_OFF:{zone}")
            self.arduino_mgr.send_command("STOP_PROCESS")
            self.log_message("Process thread exited — heaters off.")

    # ------------------------------------------------------------------
    # START / STOP
    # ------------------------------------------------------------------

    def start_process(self):
        if not self.arduino_mgr.connected:
            messagebox.showerror("Error", "Arduino not connected!")
            return

        try:
            recipe = self._load_selected_recipe()
        except Exception as e:
            messagebox.showerror("Error", str(e))
            return

        if not self.check_temperatures_ready(recipe):
            answer = messagebox.askyesno(
                "Temperature Warning",
                "Temperatures are not yet at setpoint.\n\n"
                "Click Yes to start heating and wait for stabilisation.\n"
                "Click No to cancel.")
            if not answer:
                return

        if not messagebox.askyesno(
                "Confirm", f"Start recipe '{recipe['name']}'?"):
            return

        self.process_running = True
        self.start_btn.config(state="disabled")
        self.log_message(f"Starting recipe: {recipe['name']}")
        self.arduino_mgr.send_command("START_PROCESS")
        threading.Thread(target=self.run_recipe,
                         args=(recipe,), daemon=True).start()

    def stop_process(self):
        if self.process_running:
            if messagebox.askyesno("Confirm", "Stop ALD process?"):
                self.process_running = False
                self.start_btn.config(state="normal")
                self.log_message("ALD process stopped by operator")
                self.arduino_mgr.send_command("STOP_PROCESS")
                for zone in ("REACTOR", "PRECURSOR_A", "PRECURSOR_B"):
                    self.arduino_mgr.send_command(f"PID_OFF:{zone}")

    # ------------------------------------------------------------------
    # Emergency stop
    # ------------------------------------------------------------------

    def emergency_stop(self):
        self.log_message("⚠ EMERGENCY STOP ACTIVATED ⚠")
        self.arduino_mgr.emergency_stop()
        self.process_running = False
        for k in self._setpoints:
            self._setpoints[k] = None
        self._overheat_warned.clear()
        self.start_btn.config(state="normal")
        messagebox.showwarning(
            "Emergency Stop",
            "Emergency stop executed!\nAll processes halted.")

    # ------------------------------------------------------------------
    # Close
    # ------------------------------------------------------------------

    def on_closing(self):
        if self.process_running:
            if not messagebox.askyesno(
                    "Warning",
                    "Process is running! Are you sure you want to exit?"):
                return
        self.arduino_mgr.disconnect()
        self.destroy()


